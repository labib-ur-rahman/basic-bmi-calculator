<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="btn_active">
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">@dimen/btn_font_size</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/baloo</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/btn_background_active</item>
    </style>

    <style name="btn_not_active">
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">@dimen/btn_font_size</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/baloo</item>
        <item name="android:background">@drawable/btn_background</item>
    </style>

    <style name="bmi_result_bar">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:fontFamily">@font/baloo</item>
        <item name="android:paddingTop">7dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="bmi_result_bar_text">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:fontFamily">@font/baloo_da_2</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>